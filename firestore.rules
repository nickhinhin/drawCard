rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function afterUserDoc(uid) {
      return getAfter(/databases/$(database)/documents/users/$(uid));
    }

    function drawDoc(drawId) {
      return get(/databases/$(database)/documents/draws/$(drawId));
    }

    function afterSlotDoc(drawId, slotId) {
      return getAfter(/databases/$(database)/documents/draws/$(drawId)/slots/$(slotId));
    }

    function tokenRequestPath(requestId) {
      return /databases/$(database)/documents/tokenRequests/$(requestId);
    }

    function usernamePath(name) {
      return /databases/$(database)/documents/usernames/$(name.lower());
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        userDoc(request.auth.uid).data.role == "admin";
    }

    function isLiveDraw(drawId) {
      return drawDoc(drawId).data.status == "live";
    }

    // ASCII usernames only — reduces lookalike / homoglyph spoofing.
    function isValidUsername(name) {
      return name is string
        && name.size() >= 3
        && name.size() <= 24
        && name.matches("^[A-Za-z0-9_]+$");
    }

    function willOwnUsername(name) {
      return isValidUsername(name)
        && existsAfter(usernamePath(name))
        && getAfter(usernamePath(name)).data.uid == request.auth.uid;
    }

    function ownsUsername(name) {
      return isValidUsername(name)
        && exists(usernamePath(name))
        && get(usernamePath(name)).data.uid == request.auth.uid;
    }

    function currentUsername() {
      return userDoc(request.auth.uid).data.username;
    }

    function hasNoUsername() {
      return !("username" in userDoc(request.auth.uid).data)
        || !(userDoc(request.auth.uid).data.username is string)
        || userDoc(request.auth.uid).data.username.size() == 0;
    }

    function isReleasingCurrentUsername() {
      return isValidUsername(currentUsername())
        && !existsAfter(usernamePath(currentUsername()));
    }

    function isProfileEdit(uid) {
      return isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["username", "displayName", "photoURL", "updatedAt"])
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["username"])
          || willOwnUsername(request.resource.data.username)
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["displayName"])
          || (
            request.resource.data.displayName is string
            && request.resource.data.displayName.size() <= 80
          )
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["photoURL"])
          || (
            request.resource.data.photoURL is string
            && request.resource.data.photoURL.size() <= 500
          )
        );
    }

    function isTokenSpend(uid) {
      return isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["tokens", "updatedAt"])
        && request.resource.data.tokens is number
        && request.resource.data.tokens >= 0
        && request.resource.data.tokens <= resource.data.tokens;
    }

    // Admin may mint tokens only by approving a pending tokenRequest in the same tx.
    function isAdminTokenGrant(uid) {
      return isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["tokens", "updatedAt", "lastTokenGrantRequestId"])
        && request.resource.data.lastTokenGrantRequestId is string
        && request.resource.data.lastTokenGrantRequestId.size() > 0
        && request.resource.data.lastTokenGrantRequestId.size() <= 128
        && exists(tokenRequestPath(request.resource.data.lastTokenGrantRequestId))
        && get(tokenRequestPath(request.resource.data.lastTokenGrantRequestId)).data.status
          == "pending"
        && get(tokenRequestPath(request.resource.data.lastTokenGrantRequestId)).data.uid == uid
        && get(tokenRequestPath(request.resource.data.lastTokenGrantRequestId)).data.amount is int
        && get(tokenRequestPath(request.resource.data.lastTokenGrantRequestId)).data.amount > 0
        && get(tokenRequestPath(request.resource.data.lastTokenGrantRequestId)).data.amount <= 10000
        && existsAfter(tokenRequestPath(request.resource.data.lastTokenGrantRequestId))
        && getAfter(tokenRequestPath(request.resource.data.lastTokenGrantRequestId)).data.status
          == "approved"
        && getAfter(tokenRequestPath(request.resource.data.lastTokenGrantRequestId)).data.reviewedBy
          == request.auth.uid
        && request.resource.data.tokens
          == resource.data.tokens
            + get(tokenRequestPath(request.resource.data.lastTokenGrantRequestId)).data.amount;
    }

    // 3s global chat cooldown, enforced via users/{uid}.lastChatAt in the same write.
    function chatCooldownPassed() {
      return !("lastChatAt" in userDoc(request.auth.uid).data)
        || !(userDoc(request.auth.uid).data.lastChatAt is timestamp)
        || request.time >= userDoc(request.auth.uid).data.lastChatAt + duration.value(3, "s");
    }

    function isChatRateLimitUpdate(uid) {
      return isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["lastChatAt", "updatedAt"])
        && request.resource.data.lastChatAt == request.time
        && chatCooldownPassed();
    }

    function isValidSlotPurchase(drawId) {
      return signedIn()
        && ownsUsername(userDoc(request.auth.uid).data.username)
        && isLiveDraw(drawId)
        && resource.data.status == "available"
        && request.resource.data.status == "locked"
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["status", "uid", "username", "tokenCost", "updatedAt"])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.username == userDoc(request.auth.uid).data.username
        && request.resource.data.number == resource.data.number
        && request.resource.data.tokenCost == drawDoc(drawId).data.tokenCost
        && userDoc(request.auth.uid).data.tokens >= drawDoc(drawId).data.tokenCost
        && afterUserDoc(request.auth.uid).data.tokens ==
          userDoc(request.auth.uid).data.tokens - drawDoc(drawId).data.tokenCost;
    }

    function isValidDrawRecordCreate(recordId) {
      return signedIn()
        && ownsUsername(userDoc(request.auth.uid).data.username)
        && request.resource.data.keys().hasOnly([
          "uid",
          "username",
          "drawId",
          "drawTitle",
          "roomSlug",
          "roomLink",
          "round",
          "number",
          "tokenCost",
          "createdAt"
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.username == userDoc(request.auth.uid).data.username
        && request.resource.data.drawId is string
        && request.resource.data.drawId.size() > 0
        && request.resource.data.drawId.size() <= 128
        && request.resource.data.drawTitle is string
        && request.resource.data.drawTitle.size() > 0
        && request.resource.data.drawTitle.size() <= 120
        && request.resource.data.roomSlug is string
        && request.resource.data.roomSlug.size() > 0
        && request.resource.data.roomSlug.size() <= 80
        && request.resource.data.roomLink is string
        && request.resource.data.roomLink.size() > 0
        && request.resource.data.roomLink.size() <= 500
        && request.resource.data.round is string
        && request.resource.data.round.size() > 0
        && request.resource.data.round.size() <= 40
        && request.resource.data.number is int
        && request.resource.data.number > 0
        && request.resource.data.number <= 100
        && recordId == request.resource.data.drawId + "_" + string(request.resource.data.number)
        && isLiveDraw(request.resource.data.drawId)
        && request.resource.data.tokenCost == drawDoc(request.resource.data.drawId).data.tokenCost
        && request.resource.data.drawTitle == drawDoc(request.resource.data.drawId).data.title
        && request.resource.data.createdAt == request.time
        && afterSlotDoc(
          request.resource.data.drawId,
          string(request.resource.data.number)
        ).data.uid == request.auth.uid
        && afterSlotDoc(
          request.resource.data.drawId,
          string(request.resource.data.number)
        ).data.username == request.resource.data.username
        && afterSlotDoc(
          request.resource.data.drawId,
          string(request.resource.data.number)
        ).data.tokenCost == request.resource.data.tokenCost
        && afterSlotDoc(
          request.resource.data.drawId,
          string(request.resource.data.number)
        ).data.status == "locked";
    }

    function isValidDrawRecordAdminUpdate() {
      return isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            "cardId",
            "cardName",
            "cardImageUrl",
            "collectionStatus",
            "assignedAt",
            "assignedBy",
            "updatedAt"
          ])
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["cardId"])
          || (
            request.resource.data.cardId is string
            && request.resource.data.cardId.size() > 0
            && request.resource.data.cardId.size() <= 128
          )
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["cardName"])
          || (
            request.resource.data.cardName is string
            && request.resource.data.cardName.size() > 0
            && request.resource.data.cardName.size() <= 80
          )
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["cardImageUrl"])
          || (
            request.resource.data.cardImageUrl is string
            && request.resource.data.cardImageUrl.size() <= 900000
          )
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["collectionStatus"])
          || request.resource.data.collectionStatus in ["pending", "shipping", "shipped"]
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["assignedBy"])
          || request.resource.data.assignedBy == request.auth.uid
        );
    }

    function isValidRoomMessage(drawId) {
      return signedIn()
        && ownsUsername(userDoc(request.auth.uid).data.username)
        && isLiveDraw(drawId)
        && chatCooldownPassed()
        && afterUserDoc(request.auth.uid).data.lastChatAt == request.time
        && request.resource.data.keys().hasOnly([
          "drawId",
          "source",
          "uid",
          "username",
          "text",
          "createdAt"
        ])
        && request.resource.data.drawId == drawId
        && request.resource.data.source == "draw"
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.username == userDoc(request.auth.uid).data.username
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 500
        && request.resource.data.createdAt == request.time;
    }

    function isSafeStorageProofUrl(url, uid) {
      return url is string
        && url.size() > 0
        && url.size() <= 4000
        && (
          url.matches(
            "https://firebasestorage\\.googleapis\\.com/v0/b/[^/]+/o/token-proofs%2F"
              + uid
              + "%2F[^\\s?#]+(\\?[^\\s]*)?"
          )
          || url.matches(
            "https://[a-z0-9.-]+\\.firebasestorage\\.app/v0/b/[^/]+/o/token-proofs%2F"
              + uid
              + "%2F[^\\s?#]+(\\?[^\\s]*)?"
          )
        );
    }

    function isValidTokenRequestCreate() {
      return signedIn()
        && ownsUsername(userDoc(request.auth.uid).data.username)
        && request.resource.data.keys().hasOnly([
          "uid",
          "username",
          "email",
          "amount",
          "proofMode",
          "proofPath",
          "proofFileName",
          "proofUrl",
          "status",
          "adminNote",
          "createdAt"
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.username == userDoc(request.auth.uid).data.username
        && request.resource.data.email == userDoc(request.auth.uid).data.email
        && request.resource.data.amount is int
        && request.resource.data.amount > 0
        && request.resource.data.amount <= 10000
        && request.resource.data.status == "pending"
        && request.resource.data.adminNote == ""
        && request.resource.data.proofMode == "storage"
        && request.resource.data.proofPath is string
        && request.resource.data.proofPath.matches(
          "token-proofs/" + request.auth.uid + "/[^/]+"
        )
        && request.resource.data.proofFileName is string
        && request.resource.data.proofFileName.size() > 0
        && request.resource.data.proofFileName.size() <= 200
        && isSafeStorageProofUrl(
          request.resource.data.proofUrl,
          request.auth.uid
        )
        && request.resource.data.createdAt == request.time;
    }

    function isValidTokenRequestReview() {
      return isAdmin()
        && resource.data.status == "pending"
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["status", "adminNote", "reviewedAt", "reviewedBy"])
        && request.resource.data.status in ["approved", "rejected"]
        && request.resource.data.reviewedBy == request.auth.uid
        && request.resource.data.adminNote is string
        && request.resource.data.adminNote.size() <= 500;
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasOnly([
          "uid",
          "email",
          "displayName",
          "photoURL",
          "username",
          "tokens",
          "role",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.tokens == 0
        && request.resource.data.role == "user"
        && request.resource.data.username == ""
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() <= 80
        && request.resource.data.photoURL is string
        && request.resource.data.photoURL.size() <= 500;
      allow update: if isProfileEdit(uid)
        || isTokenSpend(uid)
        || isAdminTokenGrant(uid)
        || isChatRateLimitUpdate(uid);
    }

    match /usernames/{usernameId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && isValidUsername(request.resource.data.username)
        && usernameId == request.resource.data.username.lower()
        && isValidUsername(afterUserDoc(request.auth.uid).data.username)
        && afterUserDoc(request.auth.uid).data.username.lower() == usernameId
        && (
          hasNoUsername()
          || currentUsername().lower() == usernameId
          || isReleasingCurrentUsername()
          || !ownsUsername(currentUsername())
        );

      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["username"])
        && isValidUsername(request.resource.data.username)
        && usernameId == request.resource.data.username.lower();

      allow delete: if signedIn()
        && resource.data.uid == request.auth.uid;
    }

    match /tokenRequests/{requestId} {
      allow read: if isAdmin() || isOwner(resource.data.uid);
      allow create: if isValidTokenRequestCreate();
      allow update: if isValidTokenRequestReview();
      allow delete: if false;
    }

    match /draws/{drawId} {
      allow read: if isAdmin() || (signedIn() && resource.data.status == "live");
      allow create, update: if isAdmin();
      allow delete: if isAdmin();

      match /slots/{slotId} {
        allow read: if isAdmin() || (signedIn() && isLiveDraw(drawId));
        allow create: if isAdmin();
        allow update: if isAdmin() || isValidSlotPurchase(drawId);
        allow delete: if isAdmin();
      }

      match /messages/{messageId} {
        allow read: if isAdmin() || (signedIn() && isLiveDraw(drawId));
        allow create: if isValidRoomMessage(drawId);
        allow update: if false;
        allow delete: if isAdmin();
      }
    }

    match /cards/{cardId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /drawRecords/{recordId} {
      allow read: if isAdmin() || isOwner(resource.data.uid);
      allow create: if isValidDrawRecordCreate(recordId);
      allow update: if isValidDrawRecordAdminUpdate();
      allow delete: if false;
    }
  }
}
