rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function afterUserDoc(uid) {
      return getAfter(/databases/$(database)/documents/users/$(uid));
    }

    function drawDoc(drawId) {
      return get(/databases/$(database)/documents/draws/$(drawId));
    }

    function afterSlotDoc(drawId, slotId) {
      return getAfter(/databases/$(database)/documents/draws/$(drawId)/slots/$(slotId));
    }

    function usernamePath(name) {
      return /databases/$(database)/documents/usernames/$(name.lower());
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        userDoc(request.auth.uid).data.role == "admin";
    }

    function isLiveDraw(drawId) {
      return drawDoc(drawId).data.status == "live";
    }

    function isValidUsername(name) {
      return name is string
        && name.size() >= 3
        && name.size() <= 24;
    }

    function willOwnUsername(name) {
      return isValidUsername(name)
        && existsAfter(usernamePath(name))
        && getAfter(usernamePath(name)).data.uid == request.auth.uid;
    }

    function ownsUsername(name) {
      return isValidUsername(name)
        && exists(usernamePath(name))
        && get(usernamePath(name)).data.uid == request.auth.uid;
    }

    function currentUsername() {
      return userDoc(request.auth.uid).data.username;
    }

    function hasNoUsername() {
      return !("username" in userDoc(request.auth.uid).data)
        || !(userDoc(request.auth.uid).data.username is string)
        || userDoc(request.auth.uid).data.username.size() == 0;
    }

    function isReleasingCurrentUsername() {
      return isValidUsername(currentUsername())
        && !existsAfter(usernamePath(currentUsername()));
    }

    function isProfileEdit(uid) {
      return isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["username", "displayName", "photoURL", "updatedAt"])
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["username"])
          || willOwnUsername(request.resource.data.username)
        );
    }

    function isTokenSpend(uid) {
      return isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["tokens", "updatedAt"])
        && request.resource.data.tokens is number
        && request.resource.data.tokens >= 0
        && request.resource.data.tokens <= resource.data.tokens;
    }

    function isAdminUserEdit() {
      return isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["tokens", "updatedAt"])
        && request.resource.data.tokens is number
        && request.resource.data.tokens >= 0;
    }

    function isValidSlotPurchase(drawId) {
      return signedIn()
        && ownsUsername(userDoc(request.auth.uid).data.username)
        && isLiveDraw(drawId)
        && resource.data.status == "available"
        && request.resource.data.status == "locked"
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["status", "uid", "username", "tokenCost", "updatedAt"])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.username == userDoc(request.auth.uid).data.username
        && request.resource.data.number == resource.data.number
        && request.resource.data.tokenCost == drawDoc(drawId).data.tokenCost
        && userDoc(request.auth.uid).data.tokens >= drawDoc(drawId).data.tokenCost
        && afterUserDoc(request.auth.uid).data.tokens ==
          userDoc(request.auth.uid).data.tokens - drawDoc(drawId).data.tokenCost;
    }

    // Purchase-only create: no card assignment fields; one record per draw+number.
    function isValidDrawRecordCreate(recordId) {
      return signedIn()
        && ownsUsername(userDoc(request.auth.uid).data.username)
        && request.resource.data.keys().hasOnly([
          "uid",
          "username",
          "drawId",
          "drawTitle",
          "roomSlug",
          "roomLink",
          "round",
          "number",
          "tokenCost",
          "createdAt"
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.username == userDoc(request.auth.uid).data.username
        && request.resource.data.drawId is string
        && request.resource.data.drawId.size() > 0
        && request.resource.data.number is int
        && request.resource.data.number > 0
        && recordId == request.resource.data.drawId + "_" + string(request.resource.data.number)
        && isLiveDraw(request.resource.data.drawId)
        && request.resource.data.tokenCost == drawDoc(request.resource.data.drawId).data.tokenCost
        && request.resource.data.drawTitle == drawDoc(request.resource.data.drawId).data.title
        && request.resource.data.createdAt == request.time
        && afterSlotDoc(
          request.resource.data.drawId,
          string(request.resource.data.number)
        ).data.uid == request.auth.uid
        && afterSlotDoc(
          request.resource.data.drawId,
          string(request.resource.data.number)
        ).data.username == request.resource.data.username
        && afterSlotDoc(
          request.resource.data.drawId,
          string(request.resource.data.number)
        ).data.tokenCost == request.resource.data.tokenCost
        && afterSlotDoc(
          request.resource.data.drawId,
          string(request.resource.data.number)
        ).data.status == "locked";
    }

    function isValidRoomMessage(drawId) {
      return signedIn()
        && ownsUsername(userDoc(request.auth.uid).data.username)
        && isLiveDraw(drawId)
        && request.resource.data.keys().hasOnly([
          "drawId",
          "source",
          "uid",
          "username",
          "text",
          "createdAt"
        ])
        && request.resource.data.drawId == drawId
        && request.resource.data.source == "draw"
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.username == userDoc(request.auth.uid).data.username
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 500
        && request.resource.data.createdAt == request.time;
    }

    function isValidTokenRequestCreate() {
      return signedIn()
        && ownsUsername(userDoc(request.auth.uid).data.username)
        && request.resource.data.keys().hasOnly([
          "uid",
          "username",
          "email",
          "amount",
          "proofMode",
          "proofPath",
          "proofFileName",
          "proofUrl",
          "status",
          "adminNote",
          "createdAt"
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.username == userDoc(request.auth.uid).data.username
        && request.resource.data.email == userDoc(request.auth.uid).data.email
        && request.resource.data.amount is int
        && request.resource.data.amount > 0
        && request.resource.data.amount <= 10000
        && request.resource.data.status == "pending"
        && request.resource.data.adminNote == ""
        && request.resource.data.proofMode == "storage"
        && request.resource.data.proofPath is string
        && request.resource.data.proofPath.matches(
          "token-proofs/" + request.auth.uid + "/[^/]+"
        )
        && request.resource.data.proofFileName is string
        && request.resource.data.proofFileName.size() > 0
        && request.resource.data.proofFileName.size() <= 200
        && request.resource.data.proofUrl is string
        && request.resource.data.proofUrl.size() > 0
        && request.resource.data.proofUrl.size() <= 4000
        && request.resource.data.createdAt == request.time;
    }

    function isValidTokenRequestReview() {
      return isAdmin()
        && resource.data.status == "pending"
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["status", "adminNote", "reviewedAt", "reviewedBy"])
        && request.resource.data.status in ["approved", "rejected"]
        && request.resource.data.reviewedBy == request.auth.uid
        && request.resource.data.adminNote is string
        && request.resource.data.adminNote.size() <= 500;
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.tokens == 0
        && request.resource.data.role == "user";
      allow update: if isProfileEdit(uid) || isTokenSpend(uid) || isAdminUserEdit();
    }

    match /usernames/{usernameId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && isValidUsername(request.resource.data.username)
        && usernameId == request.resource.data.username.lower()
        && isValidUsername(afterUserDoc(request.auth.uid).data.username)
        && afterUserDoc(request.auth.uid).data.username.lower() == usernameId
        && (
          hasNoUsername()
          || currentUsername().lower() == usernameId
          || isReleasingCurrentUsername()
          || !ownsUsername(currentUsername())
        );

      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["username"])
        && isValidUsername(request.resource.data.username)
        && usernameId == request.resource.data.username.lower();

      allow delete: if signedIn()
        && resource.data.uid == request.auth.uid;
    }

    match /tokenRequests/{requestId} {
      allow read: if isAdmin() || isOwner(resource.data.uid);
      allow create: if isValidTokenRequestCreate();
      allow update: if isValidTokenRequestReview();
      allow delete: if false;
    }

    match /draws/{drawId} {
      allow read: if isAdmin() || (signedIn() && resource.data.status == "live");
      allow create, update: if isAdmin();
      allow delete: if isAdmin();

      match /slots/{slotId} {
        allow read: if isAdmin() || (signedIn() && isLiveDraw(drawId));
        allow create: if isAdmin();
        allow update: if isAdmin() || isValidSlotPurchase(drawId);
        allow delete: if isAdmin();
      }

      match /messages/{messageId} {
        allow read: if isAdmin() || (signedIn() && isLiveDraw(drawId));
        allow create: if isValidRoomMessage(drawId);
        allow update: if false;
        allow delete: if isAdmin();
      }
    }

    // Card pool stays private until admin assigns into drawRecords.
    match /cards/{cardId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /drawRecords/{recordId} {
      allow read: if isAdmin() || isOwner(resource.data.uid);
      allow create: if isValidDrawRecordCreate(recordId);
      allow update: if isAdmin();
      allow delete: if false;
    }
  }
}
